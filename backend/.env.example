# ── Texture Browser — Backend Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Database (RDS PostgreSQL t3.micro) ────────────────────────────────────────
# Format: postgresql://username:password@host:port/database
# After creating your RDS instance, replace the host below with your RDS endpoint.
# Example endpoint: texture-browser.abc123.us-east-1.rds.amazonaws.com
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/texture_browser

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET_NAME=texture-browser-assets

# S3 key prefixes (no leading slash)
S3_RAW_PREFIX=textures/raw
S3_THUMBS_PREFIX=textures/thumbs

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your EC2 public IP or domain here when deployed.
# Local dev: keep these defaults.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
